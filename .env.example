# 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Key

# OpenAI API Key
OPENAI_API_KEY=sk-...n
# Embedding模型（默认使用OpenAI）
EMBEDDING_MODEL=text-embedding-ada-002

# ChromaDB配置
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=agent_memory

# 服务端口
API_PORT=8000
STREAMLIT_PORT=8501

# 记忆配置
MEMORY_MAX_TOKENS=2000
MEMORY_TOP_K=5

# RAG配置
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50